{
  "manifest_version": 3,
  "name": "FB Ad Library Scraper",
  "version": "1.0.0",
  "description": "Сбор и разбор объявлений из Facebook Ad Library для конкурентного анализа. Локально, без серверов.",
  "permissions": ["activeTab", "scripting", "storage", "tabs"],
  "host_permissions": ["*://*.facebook.com/*", "*://*.fbcdn.net/*"],
  "background": {
    "service_worker": "src/service-worker.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Ad Library Scraper"
  },
  "content_scripts": [
    {
      "matches": ["*://*.facebook.com/*"],
      "js": ["src/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.facebook.com/*"],
      "js": [
        "src/lib/ext-api.js",
        "src/lib/graphql-parser.js",
        "src/lib/dom-scraper.js",
        "src/lib/drill-in.js",
        "src/content-script.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
